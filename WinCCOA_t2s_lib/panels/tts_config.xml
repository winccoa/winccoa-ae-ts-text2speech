  <script isEscaped="1" name="ScopeLib"><![CDATA[#uses &quot;classes/TTSPanelHandler&quot;

shared_ptr&lt;TTSPanelHandler&gt; g_panelHandler = nullptr;
int g_lastManagerNum = -1;

dyn_int populateManagerList()
{
  dyn_string allDps = dpNames(&quot;TTS_engine_*&quot;, &quot;TextToSpeech&quot;);
  dyn_int managerNumbers;

  for (int i = 1; i &lt;= dynlen(allDps); i++) {
    string dpName = allDps[i];
    strreplace(dpName, &quot;System1:&quot;, &quot;&quot;);

    // Find last underscore by searching backwards
    int pos = -1;
    for (int searchPos = strlen(dpName) - 1; searchPos &gt;= 0; searchPos--) {
      int found = strpos(dpName, &quot;_&quot;, searchPos);
      if (found == searchPos) {
        pos = found;
        break;
      }
    }

    if (pos &gt;= 0) {
      string numStr = substr(dpName, pos + 1);
      int manNum = (int)numStr;
      dynAppend(managerNumbers, manNum);
    }
  }
  dynSort(managerNumbers);
  dynUnique(managerNumbers);

  dyn_string items;
  for (int i = 1; i &lt;= dynlen(managerNumbers); i++) {
    if (managerNumbers[i] == 0) {
      items[i] = &quot;0 - All Managers&quot;;
    } else {
      items[i] = managerNumbers[i];
    }
  }

  setValue(&quot;cmbManagerNum&quot;, &quot;items&quot;, items);

  return managerNumbers;
}

void loadManagerConfig(int manNumber)
{
  // Destroy old handler (this will disconnect callbacks)
  g_panelHandler = nullptr;

  // Create new handler (this will connect callbacks)
  g_panelHandler = new TTSPanelHandler(manNumber);

  // Load config and populate UI
  g_panelHandler.loadConfig();
}
]]></script>
  <script isEscaped="1" name="Initialize"><![CDATA[main()
{
  dyn_int availableManagers = populateManagerList();

  int manId = myManId();
  char manType, manNum;
  getManIdFromInt(manId, manType, manNum);
  int manNumber = (int)manNum;

  // Check if current manager exists in available list
  bool found = false;
  for (int i = 1; i &lt;= dynlen(availableManagers); i++) {
    if (availableManagers[i] == manNumber) {
      found = true;
      break;
    }
  }

  // If current manager doesn't exist, use first non-zero available manager
  if (!found &amp;&amp; dynlen(availableManagers) &gt; 1) {
    manNumber = availableManagers[2]; // Skip 0, use first real manager
  }

  setValue(&quot;cmbManagerNum&quot;, &quot;text&quot;, manNumber);
  g_lastManagerNum = manNumber;
  loadManagerConfig(manNumber);
}
]]></script>
