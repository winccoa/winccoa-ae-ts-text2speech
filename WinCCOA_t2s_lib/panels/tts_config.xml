    <script isEscaped="1" name="Changed"><![CDATA[main()
{
  string newValue;
  getValue(&quot;cmbManagerNum&quot;, &quot;text&quot;, newValue);
  
  int manNumber;
  
  // Extract number from text like &quot;3&quot; or &quot;0 - All Managers&quot;
  if (strpos(newValue, &quot; - &quot;) &gt;= 0) {
    manNumber = 0; // &quot;All Managers&quot;
  } else {
    manNumber = (int)newValue;
  }
  
  // Only reload if manager actually changed
  if (manNumber == g_lastManagerNum) {
    return;
  }
  
  DebugTN(&quot;Manager changed from &quot; + g_lastManagerNum + &quot; to: &quot; + manNumber);
  
  // Update to new manager
  g_lastManagerNum = manNumber;
  
  // Load new manager configuration (dpConnect will handle reconnecting)
  loadManagerConfig(manNumber);
}]]></script>
   </events>
