     <prop name="en_US.utf8">Apply Configuration</prop>
    </prop>
   </properties>
   <events>
    <script isEscaped="1" name="Clicked"><![CDATA[main()
{
  DebugTN(g_panelHandler);
  if (g_panelHandler == nullptr) {
    ChildPanelOnCentralModal(&quot;vision/MessageWarning&quot;, &quot;Error&quot;,
      makeDynString(&quot;$1:No configuration loaded. Please reload the panel.&quot;));
    return;
  }

  string configDpe = g_panelHandler.getConfigDpe();

  string voice;
  string language;
  int sliderValue;
  int queueSize;

  getValue(&quot;cmbVoice&quot;, &quot;text&quot;, voice);
  getValue(&quot;cmbLanguage&quot;, &quot;text&quot;, language);
  getValue(&quot;sldSpeed&quot;, &quot;value&quot;, sliderValue);
  getValue(&quot;spnQueueSize&quot;, &quot;text&quot;, queueSize);

  float speed = (float)sliderValue / 10.0;

  // Read current config, update values, write back
  string jsonConfig;
  dpGet(configDpe, jsonConfig);
  mapping config = jsonDecode(jsonConfig);

  config[&quot;voice&quot;] = voice;
  config[&quot;language&quot;] = language;
  mappingRemove(config, &quot;speed&quot;);
  config[&quot;speed&quot;] = speed;
  config[&quot;maxQueueSize&quot;] = queueSize;

  jsonConfig = jsonEncode(config);
  dpSet(configDpe, jsonConfig);
}]]></script>
   </events>
